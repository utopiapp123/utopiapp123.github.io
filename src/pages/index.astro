---
import BaseHead from '../components/BaseHead.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<main>
			<header>
				<img src="https://ww-aibot-img-1258476243.cos.ap-guangzhou.myqcloud.com/J5Jgnzc/7616336549981772661?sign=q-sign-algorithm%3Dsha1%26q-ak%3DAKIDbBpaJvdLBvpnibcYcfyPuaO5f9U1UoGo%26q-sign-time%3D1773316541%3B1773316841%26q-key-time%3D1773316541%3B1773316841%26q-header-list%3D%26q-url-param-list%3D%26q-signature%3D74348e9d6ef0d1cfa461c889a7a298082faa00fa" alt="XuWeiJie" />
				<h1>XuWeiJie</h1>
				<p class="title">量子计算研究者 | 开发者</p>
				<p class="location">📍 中国</p>
			</header>
			
			<section>
				<h2>📚 经历</h2>
				<div class="timeline">
					<div class="item">
						<h3>量子计算研究</h3>
						<p class="date">2024 - 至今</p>
						<p>专注于变分量子算法（VQE/VQA）、量子联邦学习</p>
					</div>
					<div class="item">
						<h3>开发者</h3>
						<p class="date">2020 - 至今</p>
						<p>全栈开发，Python、TypeScript、量子计算框架</p>
					</div>
				</div>
			</section>
			
			<section>
				<h2>🏆 项目</h2>
				<div class="projects">
					<a href="https://github.com/utopiapp123/quantum-distributed" target="_blank" rel="noopener">
						<strong>量子分布式计算</strong>
						<span>量子分布式算法与协议</span>
					</a>
					<a href="https://github.com/utopiapp123/quantum-federated-learning" target="_blank" rel="noopener">
						<strong>量子联邦学习</strong>
						<span>隐私保护的量子机器学习</span>
					</a>
				</div>
			</section>
			
			<footer>
				<a href="https://github.com/utopiapp123" target="_blank" rel="noopener">GitHub</a>
				<a href="/blog">博客</a>
			</footer>
		</main>
	</body>
</html>

<style>
	body {
		font-family: 'Atkinson', sans-serif;
		max-width: 680px;
		margin: 0 auto;
		padding: 3em 1.5em;
		line-height: 1.6;
	}
	
	header {
		text-align: center;
		padding-bottom: 2em;
		margin-bottom: 2em;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	
	header img {
		width: 120px;
		height: 120px;
		border-radius: 50%;
		margin-bottom: 1em;
	}
	
	header h1 {
		margin: 0.5em 0;
		color: rgb(var(--black));
	}
	
	.title {
		color: rgb(var(--gray-dark));
		margin: 0.5em 0;
	}
	
	.location {
		color: rgb(var(--gray));
		font-size: 0.9em;
	}
	
	section {
		margin-bottom: 2.5em;
	}
	
	h2 {
		font-size: 1.4em;
		margin-bottom: 1em;
		color: rgb(var(--black));
	}
	
	.timeline .item {
		margin-bottom: 1.5em;
	}
	
	.timeline h3 {
		margin: 0 0 0.3em 0;
		font-size: 1.1em;
	}
	
	.date {
		color: rgb(var(--gray));
		font-size: 0.85em;
		margin: 0 0 0.5em 0;
	}
	
	.timeline p {
		margin: 0;
		color: rgb(var(--gray-dark));
	}
	
	.projects {
		display: flex;
		flex-direction: column;
		gap: 0.8em;
	}
	
	.projects a {
		display: block;
		padding: 1em;
		background: white;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
		text-decoration: none;
		color: inherit;
		transition: all 0.2s;
	}
	
	.projects a:hover {
		border-color: var(--accent);
		box-shadow: 0 2px 8px rgba(13, 148, 136, 0.1);
	}
	
	.projects strong {
		display: block;
		color: rgb(var(--black));
		margin-bottom: 0.3em;
	}
	
	.projects span {
		font-size: 0.9em;
		color: rgb(var(--gray-dark));
	}
	
	footer {
		display: flex;
		gap: 2em;
		justify-content: center;
		padding-top: 2em;
		border-top: 1px solid rgb(var(--gray-light));
	}
	
	footer a {
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
	}
	
	footer a:hover {
		color: var(--accent-dark);
	}
	
	@media (max-width: 600px) {
		body {
			padding: 2em 1em;
		}
		
		header img {
			width: 100px;
			height: 100px;
		}
	}
</style>
