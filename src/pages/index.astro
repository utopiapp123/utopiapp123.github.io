---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import QuantumParticles from '../components/QuantumParticles.astro';
import SkillsInteractive from '../components/SkillsInteractive.astro';
import ProjectsShowcase from '../components/ProjectsShowcase.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<QuantumParticles />
		<main>
			<section class="hero">
				<h1>👋 Hello, I'm XuWeiJie</h1>
				<p class="intro">
					<strong>Quantum Computing Researcher | Developer | Explorer</strong> based in China.
					Passionate about quantum algorithms, VQE/VQA, federated learning, and building the future of quantum-classical hybrid systems.
				</p>
				
				<div class="hero-cta">
					<a href="#projects" class="btn btn-primary">View Projects</a>
					<a href="#contact" class="btn btn-secondary">Get in Touch</a>
				</div>
			</section>
			
			<SkillsInteractive />
			<ProjectsShowcase id="projects" />
			<ContactForm id="contact" />
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 1200px;
		margin: 0 auto;
		padding: 2em 1em;
		position: relative;
		z-index: 1;
	}
	
	.hero {
		text-align: center;
		padding: 4em 0;
		margin-bottom: 3em;
	}
	
	h1 {
		font-size: 3em;
		margin-bottom: 0.5em;
		background: linear-gradient(90deg, #6366f1, #8b5cf6, #ec4899);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		animation: gradient 3s ease infinite;
		background-size: 200% 200%;
	}
	
	@keyframes gradient {
		0%, 100% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
	}
	
	.intro {
		font-size: 1.3em;
		color: rgb(var(--gray-dark));
		margin-bottom: 2em;
		line-height: 1.8;
		max-width: 800px;
		margin-left: auto;
		margin-right: auto;
	}
	
	.hero-cta {
		display: flex;
		gap: 1em;
		justify-content: center;
		margin-top: 2em;
	}
	
	.btn {
		padding: 1em 2em;
		border-radius: 8px;
		text-decoration: none;
		font-weight: 600;
		transition: all 0.3s;
		display: inline-block;
	}
	
	.btn-primary {
		background: linear-gradient(90deg, #6366f1, #8b5cf6);
		color: white;
	}
	
	.btn-primary:hover {
		box-shadow: 0 4px 16px rgba(99, 102, 241, 0.4);
		transform: translateY(-2px);
	}
	
	.btn-secondary {
		background: white;
		color: var(--black);
		border: 2px solid rgb(var(--gray-light));
	}
	
	.btn-secondary:hover {
		border-color: #6366f1;
		color: #6366f1;
	}
	
	section {
		scroll-margin-top: 2em;
	}
	
	@media (max-width: 600px) {
		main {
			padding: 1em 0.75em;
		}
		
		.hero {
			padding: 2em 0;
			margin-bottom: 2em;
		}
		
		h1 {
			font-size: 1.8em;
			line-height: 1.3;
		}
		
		.intro {
			font-size: 1em;
			padding: 0 0.5em;
		}
		
		.hero-cta {
			flex-direction: column;
			align-items: center;
			gap: 0.75em;
			width: 100%;
			padding: 0 1em;
		}
		
		.btn {
			width: 100%;
			max-width: 280px;
			text-align: center;
			padding: 0.9em 1.5em;
		}
	}
</style>
