---
// 交互式联系表单组件
---

<div class="contact-section">
  <h2>📬 Get in Touch</h2>
  
  <p class="contact-intro">
    I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision.
  </p>
  
  <div class="contact-container">
    <form class="contact-form" id="contact-form">
      <div class="form-group">
        <label for="name">Name</label>
        <input type="text" id="name" name="name" required placeholder="Your name" />
      </div>
      
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required placeholder="your@email.com" />
      </div>
      
      <div class="form-group">
        <label for="subject">Subject</label>
        <select id="subject" name="subject" required>
          <option value="">Select a subject</option>
          <option value="project">💼 Project Collaboration</option>
          <option value="question">❓ Question</option>
          <option value="feedback">💡 Feedback</option>
          <option value="other">📝 Other</option>
        </select>
      </div>
      
      <div class="form-group">
        <label for="message">Message</label>
        <textarea id="message" name="message" rows="5" required placeholder="Tell me about your project or idea..."></textarea>
      </div>
      
      <button type="submit" class="submit-btn">
        <span>🚀</span> Send Message
      </button>
      
      <div class="form-status" id="form-status"></div>
    </form>
    
    <div class="contact-info">
      <h3>Connect With Me</h3>
      
      <div class="contact-links">
        <a href="https://github.com/utopiapp123" class="contact-link" target="_blank" rel="noopener noreferrer">
          <span class="contact-icon">🐙</span>
          <div>
            <span class="contact-label">GitHub</span>
            <span class="contact-url">@utopiapp123</span>
          </div>
        </a>
        
        <a href="mailto:your-email@example.com" class="contact-link">
          <span class="contact-icon">📧</span>
          <div>
            <span class="contact-label">Email</span>
            <span class="contact-url">your-email@example.com</span>
          </div>
        </a>
        
        <a href="https://linkedin.com/in/yourprofile" class="contact-link" target="_blank" rel="noopener noreferrer">
          <span class="contact-icon">💼</span>
          <div>
            <span class="contact-label">LinkedIn</span>
            <span class="contact-url">Your Profile</span>
          </div>
        </a>
        
        <a href="https://twitter.com/yourprofile" class="contact-link" target="_blank" rel="noopener noreferrer">
          <span class="contact-icon">🐦</span>
          <div>
            <span class="contact-label">Twitter</span>
            <span class="contact-url">@yourhandle</span>
          </div>
        </a>
      </div>
      
      <div class="availability">
        <div class="status-indicator online"></div>
        <span>Open to opportunities</span>
      </div>
    </div>
  </div>
</div>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusDiv = document.getElementById('form-status') as HTMLDivElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());
    
    // 显示加载状态
    statusDiv.className = 'form-status loading';
    statusDiv.textContent = '⏳ Sending...';
    
    // 模拟发送（实际使用时替换为真实的 API 调用）
    await new Promise(resolve => setTimeout(resolve, 1500));
    
    // 成功状态
    statusDiv.className = 'form-status success';
    statusDiv.textContent = '✅ Message sent! I\'ll get back to you soon.';
    form.reset();
    
    // 3 秒后清除状态
    setTimeout(() => {
      statusDiv.className = 'form-status';
      statusDiv.textContent = '';
    }, 3000);
  });

  // 输入框动画
  document.querySelectorAll('input, textarea, select').forEach(input => {
    input.addEventListener('focus', () => {
      input.parentElement?.classList.add('focused');
    });
    
    input.addEventListener('blur', () => {
      if (!input.value) {
        input.parentElement?.classList.remove('focused');
      }
    });
  });
</script>

<style>
  .contact-section {
    margin: 2em 0;
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }
  
  .contact-section h2 {
    margin-bottom: 0.5em;
    background: linear-gradient(90deg, #6366f1, #8b5cf6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .contact-intro {
    color: rgb(var(--gray-dark));
    margin-bottom: 2em;
  }
  
  .contact-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2em;
  }
  
  .contact-form {
    background: white;
    padding: 2em;
    border-radius: 16px;
    border: 1px solid rgb(var(--gray-light));
  }
  
  .form-group {
    margin-bottom: 1.5em;
    position: relative;
  }
  
  .form-group label {
    display: block;
    margin-bottom: 0.5em;
    font-weight: 500;
    color: var(--black);
  }
  
  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75em 1em;
    border: 2px solid rgb(var(--gray-light));
    border-radius: 8px;
    font-size: 1em;
    transition: all 0.3s;
    background: white;
    box-sizing: border-box;
  }
  
  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }
  
  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }
  
  .submit-btn {
    width: 100%;
    padding: 1em;
    background: linear-gradient(90deg, #6366f1, #8b5cf6);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 1em;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5em;
  }
  
  .submit-btn:hover {
    box-shadow: 0 4px 16px rgba(99, 102, 241, 0.4);
    transform: translateY(-2px);
  }
  
  .form-status {
    margin-top: 1em;
    padding: 0.75em;
    border-radius: 8px;
    text-align: center;
    font-weight: 500;
    display: none;
  }
  
  .form-status.loading {
    display: block;
    background: rgb(var(--gray-light));
    color: rgb(var(--gray-dark));
  }
  
  .form-status.success {
    display: block;
    background: #d1fae5;
    color: #065f46;
  }
  
  .form-status.error {
    display: block;
    background: #fee2e2;
    color: #991b1b;
  }
  
  .contact-info {
    background: white;
    padding: 2em;
    border-radius: 16px;
    border: 1px solid rgb(var(--gray-light));
  }
  
  .contact-info h3 {
    margin-bottom: 1.5em;
    color: var(--black);
  }
  
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 1em;
  }
  
  .contact-link {
    display: flex;
    align-items: center;
    gap: 1em;
    padding: 1em;
    border-radius: 8px;
    text-decoration: none;
    transition: all 0.3s;
    border: 1px solid rgb(var(--gray-light));
  }
  
  .contact-link:hover {
    border-color: #6366f1;
    background: rgb(var(--gray-light));
    transform: translateX(4px);
  }
  
  .contact-icon {
    font-size: 1.5em;
  }
  
  .contact-label {
    display: block;
    font-weight: 600;
    color: var(--black);
  }
  
  .contact-url {
    font-size: 0.85em;
    color: rgb(var(--gray-dark));
  }
  
  .availability {
    margin-top: 2em;
    padding: 1em;
    background: #d1fae5;
    border-radius: 8px;
    display: flex;
    align-items: center;
    gap: 0.75em;
    color: #065f46;
    font-weight: 500;
  }
  
  .status-indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #10b981;
    animation: pulse 2s infinite;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  
  @media (max-width: 768px) {
    .contact-section {
      padding: 0;
      width: 100%;
    }
    
    .contact-section h2 {
      font-size: 1.3em;
      margin-bottom: 0.5em;
      padding: 0 0.5em;
    }
    
    .contact-intro {
      font-size: 0.95em;
      margin-bottom: 1.5em;
      padding: 0 0.5em;
    }
    
    .contact-container {
      grid-template-columns: 1fr;
      gap: 1.5em;
      padding: 0;
    }
    
    .contact-form,
    .contact-info {
      padding: 1.25em;
      width: 100%;
      box-sizing: border-box;
    }
    
    .form-group {
      margin-bottom: 1.25em;
    }
    
    .form-group label {
      font-size: 0.9em;
    }
    
    .form-group input,
    .form-group select,
    .form-group textarea {
      font-size: 0.95em;
      padding: 0.7em 0.9em;
      box-sizing: border-box;
    }
    
    .submit-btn {
      padding: 0.9em;
      font-size: 0.95em;
    }
    
    .contact-info h3 {
      font-size: 1.1em;
      margin-bottom: 1.25em;
    }
    
    .contact-link {
      padding: 0.9em;
    }
    
    .contact-icon {
      font-size: 1.3em;
    }
    
    .contact-label {
      font-size: 0.9em;
    }
    
    .contact-url {
      font-size: 0.8em;
    }
    
    .availability {
      margin-top: 1.5em;
      padding: 0.9em;
      font-size: 0.9em;
    }
    
    .status-indicator {
      width: 8px;
      height: 8px;
    }
  }
</style>
